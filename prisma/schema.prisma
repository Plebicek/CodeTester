generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Answer {
  answer_id            Int  @id @default(autoincrement())
  answer_pass          Int
  answer_assignment_id Int
  answer_user          Int
  User                 User @relation(fields: [answer_user], references: [user_id], onUpdate: Restrict, map: "Answer_ibfk_1")

  @@index([answer_assignment_id], map: "assignmentId")
  @@index([answer_user], map: "user")
}

model Assigment {
  assignment_id       Int    @id @default(autoincrement())
  assignment_topic_id Int
  assignment_title    String @db.Text
  Topic               Topic  @relation(fields: [assignment_topic_id], references: [topic_id], onUpdate: Restrict, map: "Assigment_ibfk_1")
  Test                Test[]

  @@index([assignment_topic_id], map: "topic")
  @@index([assignment_topic_id], map: "topic_2")
}

model Grade {
  grade_id     Int            @id @default(autoincrement())
  grade_name   String         @db.Text
  Grade_bridge Grade_bridge[]
  Topic_bridge Topic_bridge[]
}

model Grade_bridge {
  grade_bridge_id   Int     @id @default(autoincrement())
  class_id          Int
  grade_id          Int
  grade_bridge_show Boolean @default(false)
  Class             Class   @relation(fields: [class_id], references: [class_id], onUpdate: Restrict, map: "Grade_bridge_ibfk_1")
  Grade             Grade   @relation(fields: [grade_id], references: [grade_id], onUpdate: Restrict, map: "Grade_bridge_ibfk_2")

  @@index([grade_id], map: "gradeId")
  @@index([class_id, grade_id], map: "groupId")
}

model Test {
  id          Int       @id @default(autoincrement())
  assigmentId Int
  Assigment   Assigment @relation(fields: [assigmentId], references: [assignment_id], onUpdate: Restrict, map: "Test_ibfk_1")

  @@index([assigmentId], map: "assigmentId")
}

model Topic {
  topic_id     Int            @id @default(autoincrement())
  topic_name   String         @db.Text
  Assigment    Assigment[]
  Topic_bridge Topic_bridge[]
}

model Topic_bridge {
  topic_grade_id    Int     @id @default(autoincrement())
  topic_id          Int
  grade_id          Int
  topic_bridge_lock Boolean
  class_id          Int
  Topic             Topic   @relation(fields: [topic_id], references: [topic_id], onUpdate: Restrict, map: "Topic_bridge_ibfk_1")
  Grade             Grade   @relation(fields: [grade_id], references: [grade_id], onUpdate: Restrict, map: "Topic_bridge_ibfk_2")
  Class             Class   @relation(fields: [class_id], references: [class_id], onUpdate: Restrict, map: "Topic_bridge_ibfk_3")

  @@index([grade_id], map: "gradeId")
  @@index([class_id], map: "group_id")
  @@index([topic_id, grade_id], map: "topicId")
}

model User {
  user_id       Int            @id @default(autoincrement())
  user_username String         @db.Text
  Answer        Answer[]
  Class_bridge  Class_bridge[]
}

model Class {
  class_id     Int            @id @default(autoincrement())
  class_name   String         @db.Text
  Class_bridge Class_bridge[]
  Grade_bridge Grade_bridge[]
  Topic_bridge Topic_bridge[]
}

model Class_bridge {
  class_bridge_id Int   @id @default(autoincrement())
  class_id        Int
  user_id         Int
  User            User  @relation(fields: [user_id], references: [user_id], onUpdate: Restrict, map: "Class_bridge_ibfk_1")
  Class           Class @relation(fields: [class_id], references: [class_id], onUpdate: Restrict, map: "Class_bridge_ibfk_2")

  @@index([class_id], map: "groupId")
  @@index([user_id], map: "userId")
}
